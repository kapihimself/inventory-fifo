# Copy this to .env — never commit .env itself.

# Supabase public keys (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Supabase service role — BACKEND ONLY, never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Prisma — use port 5432 for direct, 6543 for pooler
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# Internal API guard secret (openssl rand -hex 32)
API_SECRET=replace_with_32_byte_random_hex
